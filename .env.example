# CDP API Credentials (get from https://portal.cdp.coinbase.com)
CDP_API_KEY_ID=your_api_key_id_here
CDP_API_KEY_SECRET=your_api_key_secret_here

# Wallet Configuration
CDP_WALLET_SECRET=your_wallet_secret_here

# Network Configuration
NETWORK_ID=base-sepolia
# NETWORK_ID=base-mainnet  # Uncomment for mainnet

# Floe Contract Address
FLOE_CONTRACT=0xF351eDF229ded7E2e2b23E44c70e9964CbA91B2E

FLOE_API_KEY=your_floe_api_key_here
FLOE_AGENT_API_KEY=your_floe_agent_api_key_here

# Optional: API Keys for x402 endpoints
FIRECRAWL_API_KEY=
EXYAPI_KEY=

# x402-image-stub server: where payments are sent.
# Set to your shared CDP wallet address (the same one circuits 1+2 use).
X402_PAY_TO=0x2cEC5e692DA29Bf9E822dC8B114F9Ed8845c5FF1
# Public facilitator that handles payment verification on Base mainnet.
# OpenX402 is free, no key/KYC. Override if you want a different one.
X402_FACILITATOR_URL=https://facilitator.openx402.ai
# Public URL of THIS server, used by circuit-2 to call /image.
# Set after running `ngrok http 8787` on Wednesday.
X402_IMAGE_STUB_URL=http://localhost:8787


